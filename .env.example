# Ollama Configuration (local models - FREE)
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace (free token for model/dataset downloads)
HF_TOKEN=hf_your_token_here

# DeepEval (optional - for dashboard at deepeval.com)
# DEEPEVAL_API_KEY=

# LangSmith (optional - for tracing)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_your_key_here
# LANGCHAIN_PROJECT=llm-bias-sentinel

# Application
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
